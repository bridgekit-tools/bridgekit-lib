{
    "name": "bridgekit-tools/bridgekit-lib",
    "description": "A Laravel library for managing third-party provider integrations (Google, Microsoft, Meta, LinkedIn, X)",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "laravel",
        "oauth",
        "google",
        "microsoft",
        "meta",
        "linkedin",
        "integration",
        "social",
        "drive",
        "gmail"
    ],
    "authors": [
        {
            "name": "BridgeKit",
            "email": "support@bridgekit.tools"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^11.0 || ^12.0 || ^13.0",
        "illuminate/http": "^11.0 || ^12.0 || ^13.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "orchestra/testbench": "^9.0 || ^10.0 || ^11.0"
    },
    "autoload": {
        "psr-4": {
            "BridgeKit\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "BridgeKit\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "BridgeKit\\BridgeKitServiceProvider"
            ],
            "aliases": {
                "BridgeKit": "BridgeKit\\Facades\\BridgeKit"
            }
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
